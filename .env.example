# Server Environment Variables
PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/travel-plan
FRONTEND_URL=http://localhost:3000

# Transactional Email SMTP Configuration
# Supported providers: Gmail SMTP or Resend SMTP
# Use either the EMAIL_* variables below or the SMTP_* aliases for backward compatibility.

# Gmail example
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-gmail-address@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=your-gmail-address@gmail.com
EMAIL_FROM_NAME=PackGo

# Resend SMTP example
# EMAIL_SERVICE=resend
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# EMAIL_USER=resend
# EMAIL_PASS=your_resend_smtp_or_api_key
# EMAIL_FROM=noreply@your-domain.com
# EMAIL_FROM_NAME=PackGo

# Backward-compatible SMTP aliases
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-gmail-address@gmail.com
# SMTP_PASS=your_gmail_app_password
# FROM_EMAIL=your-gmail-address@gmail.com
# FROM_NAME=PackGo

# Client Environment Variables (If any)
# REACT_APP_API_URL=http://localhost:5000/api